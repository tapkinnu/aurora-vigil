{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aurora://schemas/events.schema.json",
  "title": "Aurora Vigil city events",
  "type": "object",
  "required": ["kinds", "seed_events", "timed_spawn"],
  "additionalProperties": false,
  "definitions": {
    "color": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "vec3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    },
    "audio_list": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "properties": {
    "kinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "display_name", "color", "reward_xp", "required_power", "required_action", "spawn_audio", "resolve_audio"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "color": { "$ref": "#/definitions/color" },
          "reward_xp": { "type": "integer", "minimum": 0 },
          "required_power": { "type": "string", "minLength": 1 },
          "required_action": { "type": "string", "minLength": 1 },
          "spawn_audio": { "$ref": "#/definitions/audio_list" },
          "resolve_audio": { "$ref": "#/definitions/audio_list" }
        }
      }
    },
    "seed_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "position"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "position": { "$ref": "#/definitions/vec3" }
        }
      }
    },
    "timed_spawn": {
      "type": "object",
      "required": ["types", "positions", "min_seconds", "max_seconds"],
      "additionalProperties": false,
      "properties": {
        "types": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "positions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/vec3" }
        },
        "min_seconds": { "type": "number", "minimum": 0 },
        "max_seconds": { "type": "number", "minimum": 0 }
      }
    }
  }
}
