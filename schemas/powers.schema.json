{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aurora://schemas/powers.schema.json",
  "title": "Aurora Vigil powers",
  "type": "object",
  "required": ["powers"],
  "additionalProperties": false,
  "properties": {
    "powers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "flash_color", "audio_triggers"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "flash_color": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "audio_triggers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
