{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aurora://schemas/missions.schema.json",
  "title": "Aurora Vigil missions",
  "type": "object",
  "required": ["missions"],
  "additionalProperties": false,
  "properties": {
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "objective", "target_kind", "reward_xp"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "target_kind": { "type": "string", "minLength": 1 },
          "reward_xp": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
